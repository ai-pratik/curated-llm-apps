# Copy this to .env and adjust values for your environment

# ── LLM ──────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ── Embeddings ───────────────────────────────────
EMBED_MODEL=nomic-embed-text

# ── Qdrant vector store ───────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=rag_documents

# ── Chunking ──────────────────────────────────────
CHUNK_SIZE=800
CHUNK_OVERLAP=100

# ── Retrieval ─────────────────────────────────────
RETRIEVAL_TOP_K=20     # candidates fetched before reranking
RERANK_TOP_N=4         # final chunks sent to LLM

# ── API server ────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── Gradio UI ─────────────────────────────────────
GRADIO_HOST=0.0.0.0
GRADIO_PORT=7860
